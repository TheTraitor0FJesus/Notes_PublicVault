# === VPN МОНИТОРИНГ ===

# Полный отчёт за 2 часа
alias vpnstat='/root/watch_ru.sh'

# Живой поток порта 443 (Ctrl+C чтобы остановить)
alias vpnlive='tail -f /var/log/nginx/stream_access.log'

# Только неизвестные российские IP в реальном времени
alias vpnru='tail -f /var/log/nginx/stream_access.log | grep --line-buffered -v -f /root/known_ips.txt'

# Кто подключён прямо сейчас (активные сессии)
alias vpnwho='ss -tnp | grep -E "8443|7443|9443"'

# История мониторинга по дням
alias vpnhistory='cat /root/ru_monitor_history.log'

# Все подключения за 2 недели (из всех архивов)
vpn2weeks() {
    echo "=== Все подключения за последние 2 недели ==="
    for f in /var/log/nginx/stream_access.log \
              /var/log/nginx/stream_access.log.*; do
        if [[ "$f" == *.gz ]]; then
            zcat "$f" 2>/dev/null
        else
            cat "$f" 2>/dev/null
        fi
    done | awk '{print $1}' | sort | uniq -c | sort -rn \
    | while read count ip; do
        country=$(geoiplookup "$ip" 2>/dev/null | awk -F': ' '{print $2}')
        if grep -q "^$ip$" /root/known_ips.txt 2>/dev/null; then
            tag="[FRIEND]      "
        elif echo "$country" | grep -q "Russian Federation"; then
            tag="[⚠️ UNKNOWN RU]"
        else
            tag="[FOREIGN]     "
        fi
        echo "$tag $count подкл. | $ip | $country"
    done
}

# История за конкретную дату (пример: vpnday 2026-02-20)
vpnday() {
    local date_str=$(date -d "$1" '+%d/%b/%Y' 2>/dev/null)
    if [ -z "$date_str" ]; then
        echo "Формат даты: vpnday 2026-02-20"
        return 1
    fi
    echo "=== Подключения за $1 ==="
    for f in /var/log/nginx/stream_access.log \
              /var/log/nginx/stream_access.log.*; do
        if [[ "$f" == *.gz ]]; then
            zgrep "$date_str" "$f" 2>/dev/null
        else
            grep "$date_str" "$f" 2>/dev/null
        fi
    done | awk '{print $1}' | sort | uniq -c | sort -rn \
    | while read count ip; do
        country=$(geoiplookup "$ip" 2>/dev/null | awk -F': ' '{print $2}')
        if grep -q "^$ip$" /root/known_ips.txt 2>/dev/null; then
            tag="[FRIEND]      "
        elif echo "$country" | grep -q "Russian Federation"; then
            tag="[⚠️ UNKNOWN RU]"
        else
            tag="[FOREIGN]     "
        fi
        echo "$tag $count подкл. | $ip | $country"
    done
}

# Добавить новый IP друга в список
vpnadd() { echo "$1" >> /root/known_ips.txt && echo "Добавлен: $1"; }

# Посмотреть список друзей
alias vpnfriends='cat /root/known_ips.txt'

# Список архивных логов
alias vpnarchive='ls -lh /var/log/nginx/stream_access.log*'

# Быстро узнать страну любого IP
alias ipcheck='geoiplookup'

