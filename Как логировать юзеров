Содержимое скрипта

#!/bin/bash

KNOWN_IPS="/root/known_ips.txt"
STREAM_LOG="/var/log/nginx/stream_access.log"
HTTP_LOG="/var/log/nginx/access.log"

is_known() {
    grep -q "^$1$" "$KNOWN_IPS" 2>/dev/null
}

echo "================================================"
echo "  STREAM ЛОГ — все подключения за последние 2 часа"
echo "  $(date)"
echo "================================================"

awk -v d="$(date -d '2 hours ago' '+%d/%b/%Y:%H')" \
    '$2 > "["d {print $1}' "$STREAM_LOG" 2>/dev/null \
    | sort | uniq -c | sort -rn \
    | while read count ip; do
        country=$(geoiplookup "$ip" 2>/dev/null | awk -F': ' '{print $2}')
        if is_known "$ip"; then
            tag="[FRIEND]      "
        elif echo "$country" | grep -q "Russian Federation"; then
            tag="[⚠️ UNKNOWN RU]"
        else
            tag="[FOREIGN]     "
        fi
        echo "$tag $count подкл. | $ip | $country"
    done

echo ""
echo "================================================"
echo "  ПОДОЗРИТЕЛЬНЫЕ — пустой или чужой SNI"
echo "================================================"

grep -E 'SNI="("|[^a-z])' "$STREAM_LOG" 2>/dev/null \
    | awk '{print $1}' | sort | uniq -c | sort -rn \
    | head -20 \
    | while read count ip; do
        country=$(geoiplookup "$ip" 2>/dev/null | awk -F': ' '{print $2}')
        if is_known "$ip"; then
            tag="[FRIEND]"
        elif echo "$country" | grep -q "Russian Federation"; then
            tag="[⚠️ UNKNOWN RU]"
        else
            tag="[FOREIGN]"
        fi
        echo "$tag $count раз | $ip | $country"
    done

Сделать исполняемым
    chmod +x /root/watch_ru.sh

